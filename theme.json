{
	"$schema": "http://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Deltra",
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	],
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "760px",
			"wideSize": "1360px"
		},
		"typography": {
			"dropCap": false,
			"fontSizes": [
				{
					"fluid": {
						"min": "1rem",
						"max": "1rem"
					},
					"size": "1rem",
					"slug": "small"
				},
				{
					"fluid": {
						"min": "1.125",
						"max": "1.25rem"
					},
					"size": "1.25rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"min": "1.875rem",
						"max": "2.25rem"
					},
					"size": "2.25rem",
					"slug": "large"
				},
				{
					"fluid": {
						"min": "2.25rem",
						"max": "3rem"
					},
					"size": "3rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"min": "3rem",
						"max": "3.75rem"
					},
					"size": "3.75rem",
					"slug": "xx-large"
				}
			]
		},
		"color": {
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#FFFFFF",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#000000",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#F3CD1E",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#072446",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "#F3F4FE",
					"name": "Tertiary",
					"slug": "tertiary"
				},
				{
					"color": "#494B83",
					"name": "Indigo",
					"slug": "indigo"
				}
			]
		},
		"custom": {
			"typography": {
				"fontSmoothing": {
					"moz": "grayscale",
					"webkit": "antialiased"
				},
				"font-weight": {
					"black": "900",
					"extraBold": "800",
					"bold": "700",
					"semiBold": "600",
					"medium": "500",
					"regular": "400",
					"light": "300",
					"extraLight": "200",
					"thin": "100"
				},
				"line-height": {
					"tiny": 1.15,
					"small": 1.2,
					"medium": 1.4,
					"normal": 1.6,
					"large": 1.8
				}
			}
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"typography": {
			"fontSize": "1.15rem",
			"fontWeight": "var(--wp--custom--font-weight--regular)",
			"lineHeight": "1.384"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "var(--wp--custom--typography--font-weight--semi-bold)",
					"letterSpacing": "-0.02em"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "var(--wp--custom--typography--font-weight--semi-bold)",
					"letterSpacing": "-0.02em"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "var(--wp--custom--typography--font-weight--semi-bold)",
					"letterSpacing": "-0.02em"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "clamp(1.5rem, 1.5rem + ((1vw - 0.48rem) * 0.721), 1.875rem)",
					"fontWeight": "var(--wp--custom--typography--font-weight--semi-bold)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "clamp(1.25rem, 1.25rem + ((1vw - 0.48rem) * 0.721), 1.5rem)",
					"fontWeight": "var(--wp--custom--typography--font-weight--medium)"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "1.125rem",
					"fontWeight": "400",
					"letterSpacing": "0.03em"
				}
			},
			"link": {
				"color": {
					"text": "inherit"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary)"
					},
					"typography": {
						"textDecoration": "underline"
					}
				},
				":active": {
					"color": {
						"text": "var(--wp--preset--color--secondary)"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				":focus": {
					"typography": {
						"textDecoration": "underline dashed"
					}
				}
			}
		},
		"blocks": {
			"core/button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--contrast)"
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		}
	}
}
